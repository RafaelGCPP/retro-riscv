# Auto detect text files and normalize line endings to LF
* text=auto

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Batch files
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Docker
Dockerfile text eol=lf
.dockerignore text eol=lf

# Git
.gitattributes text eol=lf
.gitignore text eol=lf

# Text files
*.txt text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.conf text eol=lf
*.config text eol=lf

# Binary files
*.bin binary
*.o binary
*.a binary
*.so binary
*.dll binary
*.exe binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary

# FPGA files
*.v text eol=lf
*.vhd text eol=lf
*.vhdl text eol=lf
*.xdc text eol=lf
